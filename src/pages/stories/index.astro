---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { filterPublished, sortByOrderThenTitle, withBase, entrySlug } from "../../lib/content";

const stories = sortByOrderThenTitle(filterPublished(await getCollection("stories")));
---

<BaseLayout title="סיפורים" current="stories">
  <div class="container">
    <h1 class="page-title">סיפורים</h1>
    <p class="page-intro">סיפורים קצרים בעברית.</p>
    {
      stories.length === 0 ? (
        <p class="item-meta">עדיין לא פורסמו סיפורים.</p>
      ) : (
        <ul class="section-list">
          {stories.map((story) => (
            <li>
              <a href={withBase(`stories/${entrySlug(story.id)}/`)}>
                {story.data.title}
              </a>
              {story.data.summary && (
                <span class="item-summary">{story.data.summary}</span>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
