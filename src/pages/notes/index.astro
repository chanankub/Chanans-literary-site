---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import NotesToc from "../../components/NotesToc.astro";
import { filterPublished, sortByOrderThenTitle, withBase, entrySlug } from "../../lib/content";
import { HAKDAMA_SLUG, hakdamaToc } from "../../lib/notes-toc";

const notes = sortByOrderThenTitle(filterPublished(await getCollection("notes")));
const otherNotes = notes.filter((n) => entrySlug(n.id) !== HAKDAMA_SLUG);
---

<BaseLayout title="איך למדתי לאהוב שירה" current="notes">
  <div class="container">
    <h1 class="page-title">איך למדתי לאהוב שירה</h1>
  </div>
  <div class="container container--wide">
    <NotesToc noteSlug={HAKDAMA_SLUG} entries={hakdamaToc} />
    <p class="notes-toc__read">
      <a href={withBase(`notes/${HAKDAMA_SLUG}/`)}>לקריאה מההתחלה →</a>
    </p>
    {
      otherNotes.length > 0 && (
        <ul class="section-list">
          {otherNotes.map((note) => (
            <li>
              <a href={withBase(`notes/${entrySlug(note.id)}/`)}>
                {note.data.title}
              </a>
              {note.data.summary && (
                <span class="item-summary">{note.data.summary}</span>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
