---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { filterPublished, formatHebrewDate, sortByOrderThenTitle } from "../../lib/content";

const notes = sortByOrderThenTitle(filterPublished(await getCollection("notes")));
---

<BaseLayout title="הערות" current="notes">
  <div class="container">
    <h1 class="page-title">הערות</h1>
    <p class="page-intro">הערות אישיות וכתיבה.</p>
    {
      notes.length === 0 ? (
        <p class="item-meta">עדיין לא פורסמו הערות.</p>
      ) : (
        <ul class="section-list">
          {notes.map((note) => (
            <li>
              <a href={`${import.meta.env.BASE_URL}notes/${note.id}/`}>
                {note.data.title}
              </a>
              {note.data.summary && (
                <span class="item-summary">{note.data.summary}</span>
              )}
              {note.data.date && (
                <span class="item-meta">{formatHebrewDate(note.data.date)}</span>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
