---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="בית" current="home">
  <div class="container">
    <h1 class="page-title">ברוכים הבאים</h1>
    <p class="page-intro">
      אתר זה מוקדש ליצירה ספרותית: תרגומי שירה, סיפורים קצרים והערות אישיות.
    </p>
    <nav aria-label="מדורים">
      <ul class="section-list">
        <li>
          <a href={`${import.meta.env.BASE_URL}translations/`}>תרגומים</a>
          <span class="item-summary">שירה מקורית לצד תרגום עברי, שורה מול שורה</span>
        </li>
        <li>
          <a href={`${import.meta.env.BASE_URL}stories/`}>סיפורים</a>
          <span class="item-summary">סיפורים קצרים בעברית</span>
        </li>
        <li>
          <a href={`${import.meta.env.BASE_URL}notes/`}>הערות</a>
          <span class="item-summary">הערות אישיות וכתיבה</span>
        </li>
      </ul>
    </nav>
  </div>
</BaseLayout>
