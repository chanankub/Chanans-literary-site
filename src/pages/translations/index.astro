---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatPoetEnglishCredit,
  publishedContentEntries,
  sortPoemsByAuthorBirth,
  withBase,
  entrySlug,
} from "../../lib/content";

const poems = sortPoemsByAuthorBirth(
  publishedContentEntries(await getCollection("poems")),
);
---

<BaseLayout title="תרגומים" current="translations">
  <div class="container">
    <h1 class="page-title">תרגומים</h1>
    <p class="page-intro">תרגומי שירה — המקור והתרגום זה לצד זה.</p>
    {
      poems.length === 0 ? (
        <p class="item-meta">עדיין לא פורסמו תרגומים.</p>
      ) : (
        <ul class="section-list">
          {poems.map((poem) => (
            <li>
              <a href={withBase(`translations/${entrySlug(poem.id)}/`)}>
                {poem.data.footnote && poem.data.footnoteOn === "title"
                  ? `${poem.data.title}*`
                  : poem.data.title}
              </a>
              <span class="item-meta">
                {poem.data.author}
                {
                  poem.data.authorEn && (
                    <>
                      {" · "}
                      <span dir="ltr" lang="en">
                        {formatPoetEnglishCredit(
                          poem.data.authorEn,
                          poem.data.authorBirth,
                          poem.data.authorDeath,
                          {
                            deathAsterisk:
                              Boolean(poem.data.footnote) &&
                              poem.data.footnoteOn === "death",
                            nameAsterisk:
                              Boolean(poem.data.footnote) &&
                              poem.data.footnoteOn === "author",
                          },
                        )}
                      </span>
                    </>
                  )
                }
              </span>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</BaseLayout>
