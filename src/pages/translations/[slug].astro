---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PoemParallel from "../../components/PoemParallel.astro";
import {
  entrySlug,
  formatPoetEnglishCredit,
  publishedContentEntries,
} from "../../lib/content";

export async function getStaticPaths() {
  const poems = publishedContentEntries(await getCollection("poems"));
  return poems.map((poem) => ({
    params: { slug: entrySlug(poem.id) },
    props: { poem },
  }));
}

const { poem } = Astro.props;
const {
  title,
  originalTitle,
  author,
  authorEn,
  authorBirth,
  authorDeath,
  pairLayout,
  altTitle,
  altPairs,
  pairs,
  footnote,
  footnoteOn,
  footnotes,
  epigraph,
  sourceLang,
} = poem.data;
const poetEnglish = authorEn
  ? formatPoetEnglishCredit(authorEn, authorBirth, authorDeath, {
      deathAsterisk: Boolean(footnote) && footnoteOn === "death",
      nameAsterisk: Boolean(footnote) && footnoteOn === "author",
    })
  : null;
const displayTitle =
  footnote && footnoteOn === "title" ? `${title}*` : title;
---

<BaseLayout title={title} current="translations">
  <div class="container container--wide">
    <header class="poem-header">
      <h1 class="page-title">{displayTitle}</h1>
      <p class="poem-meta">
        {originalTitle && <span>{originalTitle} · </span>}
        {
          footnote && footnoteOn === "author" ? (
            <span>
              {author}
              <span aria-hidden="true">*</span>
            </span>
          ) : (
            author
          )
        }
      </p>
      {
        poetEnglish && (
          <p class="poem-meta poem-meta--en" dir="ltr" lang="en">
            {poetEnglish}
          </p>
        )
      }
    </header>
    {
      epigraph && (
        <blockquote class="poem-epigraph">
          <div class="poem-epigraph__row">
            <p class="poem-cell poem-cell--la" dir="ltr" lang="en">
              {epigraph.original}
            </p>
            <p class="poem-cell poem-cell--he" dir="rtl" lang="he">
              {epigraph.translation}
            </p>
          </div>
          {(epigraph.attribution || epigraph.attributionHe) && (
            <div class="poem-epigraph__row poem-epigraph__attr">
              <p class="poem-cell poem-cell--la" dir="ltr" lang="en">
                {epigraph.attribution && `—${epigraph.attribution}`}
              </p>
              <p class="poem-cell poem-cell--he" dir="rtl" lang="he">
                {epigraph.attributionHe && `–${epigraph.attributionHe}`}
              </p>
            </div>
          )}
        </blockquote>
      )
    }
    <PoemParallel
      pairs={pairs}
      layout={pairLayout}
      altTitle={altTitle}
      altPairs={altPairs}
      sourceLang={sourceLang}
    />
    {
      footnote && (
        <p class="poem-footnote">*{footnote}</p>
      )
    }
    {
      footnotes && footnotes.length > 0 && (
        <ol class="poem-footnotes">
          {footnotes.map((note) => (
            <li>{note}</li>
          ))}
        </ol>
      )
    }
  </div>
</BaseLayout>
