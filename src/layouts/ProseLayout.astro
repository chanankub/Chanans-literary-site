---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  summary?: string;
  section: "stories" | "notes";
  wide?: boolean;
}

const { title, summary, section, wide = false } = Astro.props;
const current = section === "stories" ? "stories" : "notes";
---

<BaseLayout title={title} description={summary ?? title} current={current}>
  <article class:list={["prose", wide ? "container container--wide" : "container"]}>
    <header id="top">
      <h1 class="page-title">{title}</h1>
    </header>
    <div class="prose-body">
      <slot />
    </div>
  </article>
</BaseLayout>
