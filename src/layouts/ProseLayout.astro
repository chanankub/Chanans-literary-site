---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  summary?: string;
  section: "stories" | "notes";
}

const { title, summary, section } = Astro.props;
const current = section === "stories" ? "stories" : "notes";
---

<BaseLayout title={title} description={summary ?? title} current={current}>
  <article class="container prose">
    <header>
      <h1 class="page-title">{title}</h1>
    </header>
    <div class="prose-body">
      <slot />
    </div>
  </article>
</BaseLayout>
