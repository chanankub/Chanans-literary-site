---
interface Props {
  current?: "home" | "translations" | "stories" | "notes" | "contact";
}

import { withBase } from "../lib/content";

const { current } = Astro.props;

const links = [
  { href: withBase(), label: "ראשי", id: "home" as const },
  { href: withBase("translations/"), label: "תרגומים", id: "translations" as const },
  { href: withBase("stories/"), label: "סיפורים", id: "stories" as const },
  { href: withBase("notes/"), label: "איך למדתי לאהוב שירה", id: "notes" as const },
  { href: withBase("contact/"), label: "יצירת קשר", id: "contact" as const },
];
---

<nav aria-label="ניווט ראשי">
  <ul class="site-nav">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={current === link.id ? "page" : undefined}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
