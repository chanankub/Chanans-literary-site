# Copy to .env and fill in for the contact page (comments + mailing list).
# For GitHub Actions deploy, add the same as repository secrets.

# Cusdis (https://cusdis.com) — free; readers comment with name + email only
PUBLIC_CUSDIS_HOST=https://cusdis.com
PUBLIC_CUSDIS_APP_ID=

# Buttondown newsletter (https://buttondown.com) — username only
PUBLIC_BUTTONDOWN_USER=

# Fallback contact email when Buttondown is not set
PUBLIC_CONTACT_EMAIL=
